# Core RAG configuration
GENERATOR=gemini
VECTOR_STORE=faiss
RETRIEVER=hybrid    # RETRIEVER options: simple, dense, hybrid, metadata, bm25
RERANKER=simple
TOP_K=3

# Gemini configuration
GEMINI_API_KEY=
DEFAULT_MODEL=gemini-3.1-flash-lite-preview
AVAILABLE_MODELS=gemini-3.1-flash-lite-preview,gemini-3-flash-preview
ALLOW_CUSTOM_MODELS=true

# Document source (local or gcs)
DOCUMENT_SOURCE=local
GCS_BUCKET_NAME=
GCS_PREFIX=

# GCP project (used for cloud deployment)
GOOGLE_CLOUD_PROJECT=

# Internal service URL (do not change for Docker)
RAG_API_URL=http://rag-engine:8001